---
import WhatsAppFab from '../components/WhatsAppFab.astro';
import defaultOgImage from '../assets/images/Insectocapturador-Industrial-Encendido.webp';
import '@fontsource-variable/inter';

interface Props {
	title: string;
    description?: string;
    image?: string;
    preloadDesktopImage?: string;
    preloadMobileImage?: string;
}

const { 
    title, 
    description = "Líderes en trampas de luz UV e insectocutores de acero inoxidable 304 en Perú. Cumplimiento garantizado para auditorías DIGESA y HACCP.",
    image = defaultOgImage.src,
    preloadDesktopImage,
    preloadMobileImage
} = Astro.props;

// siteUrl is used to resolve absolute URLs for SEO and social sharing.
const siteUrl = Astro.site ? new URL(Astro.site) : new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const resolvedOgImage = new URL(image, siteUrl);
---

<!doctype html>
<html lang="es" class="scroll-smooth scroll-pt-20">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <!-- LCP Preload - Positioned at top of <head> for earliest discovery -->
        {preloadDesktopImage && <link rel="preload" as="image" href={preloadDesktopImage} media="(min-width: 768px)" fetchpriority="high" />}
        {preloadMobileImage && <link rel="preload" as="image" href={preloadMobileImage} media="(max-width: 767px)" fetchpriority="high" />}

		<link rel="icon" type="image/png" href="/images/favicon-small.png" />
		<meta name="generator" content={Astro.generator} />

        {/* The Content Security Policy is applied in production. */}
        {import.meta.env.PROD && (
            <meta http-equiv="Content-Security-Policy" content="default-src 'self' data:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://challenges.cloudflare.com https://www.googletagmanager.com https://ssl.google-analytics.com https://www.google-analytics.com; connect-src 'self' https://challenges.cloudflare.com https://www.google-analytics.com; frame-src 'self' https://challenges.cloudflare.com https://www.google.com; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:;" />
        )}

        <!-- Google Tag Manager -->
        <script type="text/partytown">(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-PZT4D69');</script>
        <!-- End Google Tag Manager -->

        <!-- Resource Hints -->
        <link rel="preconnect" href="https://challenges.cloudflare.com">
        
        <!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={resolvedOgImage} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={resolvedOgImage} />

        <!-- JSON-LD / SEO -->
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "Organization",
          "name": "Flash Killer",
          "url": siteUrl.toString(),
          "logo": new URL("/images/favicon.png", siteUrl).toString(),
          "description": description,
          "sameAs": [
            "https://www.facebook.com/capturadoresdemoscas",
            "https://www.linkedin.com/company/insectocapturadores-flash-killer/"
          ],
          "address": {
            "@type": "PostalAddress",
            "addressCountry": "PE"
          },
          "contactPoint": {
            "@type": "ContactPoint",
            "contactType": "sales",
            "url": new URL("/contactanos", siteUrl).toString()
          }
        })} />
	</head>
	<body class="bg-white text-industrial-dark">
        <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[10000] focus:bg-primary focus:text-white focus:p-4 focus:rounded-sm focus:font-bold">
            Saltar al contenido principal
        </a>
        <!-- Google Tag Manager (noscript) -->
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PZT4D69"
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        <!-- End Google Tag Manager (noscript) -->
		<slot />
        <WhatsAppFab />
	</body>
</html>

<style is:global>
    :root {
        font-family: 'Inter Variable', sans-serif;
        font-display: swap;
    }
</style>
