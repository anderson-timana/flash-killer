---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Text from './Text.astro';

interface Props {
  name: string;
  spec: string;
  imageAlt: string;
  href: string;
  image?: ImageMetadata;
}

const { name, spec, imageAlt, href, image } = Astro.props;
---
<div class="group border border-industrial-grey/20 p-4 bg-white h-full flex flex-col">
  <div class="aspect-square bg-industrial-white mb-4 overflow-hidden relative flex-shrink-0">
    <div class="w-full h-full flex items-center justify-center group-hover:scale-105 transition-transform duration-300">
      {image ? (
        <Image 
          src={image} 
          alt={imageAlt} 
          width={450}
          height={450}
          class="w-full h-full object-contain p-4" 
          loading="lazy"
          decoding="async"
        />
      ) : (
        <Text variant="sub">{imageAlt}</Text>
      )}
    </div>
  </div>
  <Text as="h3" variant="vr2" class="mb-2">{name}</Text>
  <Text variant="sub" class="mb-4">{spec}</Text>
  <div class="mt-auto">
    <a href={href} class="inline-block w-full text-center py-3 bg-industrial-dark text-white font-bold text-sm uppercase hover:bg-primary transition-colors">Ver Detalles</a>
  </div>
</div>
