---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Text from './Text.astro';

interface Props {
  name: string;
  spec: string;
  imageAlt: string;
  href: string;
  image?: ImageMetadata;
}

const { name, spec, imageAlt, href, image } = Astro.props;
---
<div class="border border-industrial-grey/20 bg-white h-full transition-all shadow-sm hover:shadow-md hover:border-primary/30 p-4">
  <a href={href} class="flex flex-col h-full no-underline text-inherit group outline-none">
    <div class="aspect-square bg-industrial-white mb-4 overflow-hidden relative flex-shrink-0">
      <div class="w-full h-full flex items-center justify-center group-hover:scale-105 transition-transform duration-300">
        {image ? (
          <Image 
            src={image} 
            alt={imageAlt} 
            width={450}
            height={450}
            class="w-full h-full object-contain p-4" 
            loading="lazy"
            decoding="async"
          />
        ) : (
          <Text variant="sub">{imageAlt}</Text>
        )}
      </div>
    </div>
    
    <Text as="h3" variant="vr2" class="mb-2 group-hover:text-primary group-focus:text-primary transition-colors">
      {name}
    </Text>
    
    <Text variant="sub" class="mb-4 text-industrial-grey">
      {spec}
    </Text>
    
    <div class="mt-auto">
      <div class="inline-block w-full text-center py-3 bg-industrial-dark text-white font-bold text-sm uppercase group-hover:bg-primary group-focus:bg-primary transition-colors">
        Ver Detalles
      </div>
    </div>
  </a>
</div>
