---
/**
 * WhatsApp FAB Component
 * Obfuscated to protect against scrapers.
 */
const phone = "51984217123";
const encodedPhone = Buffer.from(phone).toString('base64');
---
<a 
  id="whatsapp-fab"
  href="#" 
  target="_blank" 
  rel="noopener noreferrer" 
  class="fixed bottom-4 right-4 md:bottom-6 md:right-6 z-[100] bg-[#25D366] text-white p-3.5 md:p-4 rounded-full shadow-2xl hover:scale-110 hover:bg-[#128C7E] transition-all duration-700 group animate-bounce-subtle opacity-0 translate-y-4 pointer-events-none"
  aria-label="Contactar por WhatsApp"
  data-wa-encoded={encodedPhone}
>
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    width="32" 
    height="32" 
    viewBox="0 0 448 512" 
    fill="currentColor"
    class="drop-shadow-sm"
  >
    <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18.2-5.1-1.9-8.8-2.8-12.4 2.8-3.7 5.6-14.3 18.2-17.6 22.2-3.2 4-6.5 4.4-12 1.6-5.5-2.8-23.3-8.6-44.4-27.4-16.4-14.6-27.5-32.8-30.7-38.3-3.2-5.6-.3-8.6 2.5-11.4 2.5-2.5 5.5-6.5 8.3-9.7 2.8-3.3 3.7-5.6 5.6-9.3 1.9-3.7.9-6.9-.5-9.7-1.4-2.8-12.4-30-17-41.1-4.5-10.8-9.1-9.3-12.5-9.3-3.2 0-6.9-.1-10.6-.1-3.7 0-9.7 1.4-14.8 7.4-5.1 6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
  </svg>
  
  <!-- Tooltip -->
  <span class="absolute right-full mr-4 top-1/2 -translate-y-1/2 bg-industrial-dark text-white text-xs py-2 px-4 rounded-sm whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none shadow-xl border border-white/10 hidden md:block">
    ¿Necesita ayuda? Chatee con un experto
  </span>
</a>

<script>
    // Lazy load contact utilities
    window.addEventListener('load', () => {
        if ('requestIdleCallback' in window) {
            requestIdleCallback(() => import('../assets/scripts/contact-utils.js'));
        } else {
            setTimeout(() => import('../assets/scripts/contact-utils.js'), 1000);
        }
    });
</script>

<style>
  @keyframes bounce-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }
  .animate-bounce-subtle {
    animation: bounce-subtle 3s ease-in-out infinite;
  }
</style>
