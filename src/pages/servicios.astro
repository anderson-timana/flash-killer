---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Section from '../components/Section.astro';
import Text from '../components/Text.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: "Ingeniería de Soluciones",
    desc: "Diseño y fabricación de equipos UV a medida para infraestructuras complejas o requisitos específicos de auditoría.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" /></svg>`
  },
  {
    title: "Instalación Técnica Certificada",
    desc: "Montaje estratégico de equipos siguiendo normativas de ubicación para maximizar la tasa de captura y el cumplimiento sanitario.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>`
  },
  {
    title: "Mantenimiento Preventivo",
    desc: "Programas anuales de revisión, limpieza y calibración de balastros para asegurar la eficiencia continua del espectro UV.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>`
  },
  {
    title: "Logística de Insumos",
    desc: "Abastecimiento inmediato de lámparas UV Philips/Sylvania y placas adhesivas certificadas para evitar interrupciones operativas.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" /></svg>`
  }
];
---

<Layout 
  title="Servicios de Mantenimiento y Repuestos UV | Flash Killer"
  description="Soporte técnico especializado para insectocutores y trampas de luz. Venta de repuestos, balastros y tubos UV con entrega inmediata en todo el país."
>
  <Navbar />
  <main class="mt-20">
    <Section padding="medium">
      <div class="max-w-4xl mx-auto text-center mb-16">
        <Text variant="sub" class="text-primary font-bold mb-4">Gestión Integral de Higiene</Text>
        <Text as="h1" variant="vr2" class="mb-6">Servicios Técnicos y Auditoría de Plagas</Text>
        <Text variant="body">
          Garantizamos la continuidad operativa de sus procesos críticos. Nuestra infraestructura de servicios está diseñada para industrias auditadas bajo estándares HACCP, DIGESA y BRC, asegurando ambientes libres de vectores contaminantes.
        </Text>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {services.map(service => (
          <div class="bg-industrial-white p-8 border border-industrial-grey/10 hover:border-primary/30 transition-all group">
            <div class="text-primary mb-6 group-hover:scale-110 transition-transform inline-block" set:html={service.icon} />
            <Text as="h3" variant="vr2" class="text-xl mb-4">{service.title}</Text>
            <Text variant="body" class="text-sm">{service.desc}</Text>
          </div>
        ))}
      </div>
    </Section>

    <Section padding="medium" class="bg-industrial-dark text-white mb-24">
      <div class="grid md:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
        <div>
          <Text as="h2" variant="vr2" class="text-white mb-6">Estándares de Calidad</Text>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-primary font-bold">✓</span>
              <Text variant="body" class="text-industrial-grey text-sm">Protocolos alineados a la Norma Sanitaria 007-98-SA.</Text>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary font-bold">✓</span>
              <Text variant="body" class="text-industrial-grey text-sm">Técnicos certificados en seguridad eléctrica industrial.</Text>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary font-bold">✓</span>
              <Text variant="body" class="text-industrial-grey text-sm">Garantía real sobre instalación y componentes.</Text>
            </li>
          </ul>
        </div>
        <div class="bg-white/5 p-8 border border-white/10">
          <Text variant="body" class="text-white italic">"Externalice su control de plagas con expertos. Reduzca riesgos de contaminación cruzada y asegure la aprobación de su próxima inspección sanitaria."</Text>
        </div>
      </div>
    </Section>

    <ContactForm 
      hook="Solicitar Visita Técnica" 
      body="Coordine una evaluación en planta con nuestros ingenieros especialistas." 
      initialProduct="otros"
    />
  </main>
  <Footer />
</Layout>
