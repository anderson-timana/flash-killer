---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Section from '../../components/Section.astro';
import Text from '../../components/Text.astro';
import ContactForm from '../../components/ContactForm.astro';
import ProductTechShowcase from '../../components/ProductTechShowcase.astro';
import Footer from '../../components/Footer.astro';
import { products } from '../../data/products';
import { Image } from 'astro:assets';

export function getStaticPaths() {
  return products.map(product => ({
    params: { id: product.id },
    props: product
  }));
}

const { name, subtitle, desc, specs, safety, images } = Astro.props;
---

<Layout 
  title={`${name} | ${subtitle} | Flash Killer`}
  description={`${desc.slice(0, 155)}...`}
>
  <Navbar />
  <main class="mt-20">
    <!-- Block 1: Product Hero (Conversion Cluster) -->
    <Section padding="medium" class="grid md:grid-cols-2 gap-12 items-center">
       <div class="flex flex-col gap-4">
           <div class="bg-industrial-white aspect-square flex items-center justify-center overflow-hidden relative group">
              {images && images.length > 0 ? (
                <Image 
                  id="main-image" 
                  src={images[0]} 
                  alt={name} 
                  class="w-full h-full object-contain p-8 animate-fade-in transition-opacity duration-300"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              ) : (
                <Text variant="sub" class="text-xl">{name}</Text>
              )}

              {/* Navigation Arrows - Only if more than 1 image */}
              {images && images.length > 1 && (
                <>
                  <button id="prev-btn" class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-primary hover:text-white text-industrial-dark p-2 rounded-full shadow-md transition-all opacity-0 group-hover:opacity-100" aria-label="Imagen anterior">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                    </svg>
                  </button>
                  <button id="next-btn" class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-primary hover:text-white text-industrial-dark p-2 rounded-full shadow-md transition-all opacity-0 group-hover:opacity-100" aria-label="Siguiente imagen">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                  </button>
                </>
              )}
           </div>
           
           <!-- Thumbnails -->
           {images && images.length > 1 && (
             <div class="flex gap-4 overflow-x-auto pb-2 justify-center">
               {images.map((img, index) => (
                 <button 
                   class={`thumbnail-btn w-20 h-20 border-2 bg-industrial-white flex items-center justify-center cursor-pointer focus:outline-none transition-all ${index === 0 ? 'border-primary' : 'border-transparent hover:border-industrial-grey/30'}`}
                   data-image={img.src}
                   data-index={index}
                   aria-label={`Ver imagen ${index + 1}`}
                 >
                   <Image 
                    src={img} 
                    alt="" 
                    class="w-full h-full object-contain p-2" 
                    loading="lazy"
                    decoding="async"
                   />
                 </button>
               ))}
             </div>
           )}
       </div>

       <div>
          <!-- Decoupled SEO Hierarchy: H2/VR1 for Visual Hook, H1/VR3 for SEO Intent -->
          <Text as="h2" variant="vr1" class="mb-2">{name}</Text>
          <Text as="h1" variant="vr3" class="mb-6 text-industrial-grey">{subtitle}</Text>
          
          <Text variant="body" class="mb-8">{desc}</Text>
          
          <div class="flex flex-col items-start gap-4">
            <a href="#cotizar" class="bg-primary text-white px-8 py-4 rounded-sm text-lg font-bold hover:scale-105 transition-transform inline-block">
                Cotizar este Equipo
            </a>
            <a href="#" class="text-primary font-bold uppercase tracking-wider text-sm flex items-center gap-2 hover:underline">
                <span class="text-xl">↓</span> Descargar Ficha Técnica (PDF)
            </a>
          </div>
       </div>
    </Section>

    <!-- Block 2: Tech Data Cluster (Specs & Safety) -->
    <Section padding="medium" class="bg-industrial-white border-y border-industrial-grey/10">
      <div class="max-w-6xl mx-auto">
         <ProductTechShowcase specs={specs} safety={safety} />
      </div>
    </Section>

    <div id="cotizar">
        <ContactForm 
            hook={`Cotizar ${name}`} 
            body="Envíenos sus datos para recibir una cotización formal." 
            initialProduct={Astro.params.id}
        />
    </div>
  </main>
  <Footer />
</Layout>

<script>
  // Simple vanilla JS for gallery interaction
  document.addEventListener('astro:page-load', () => {
    initGallery();
  });

  // Also run on initial load
  initGallery();

  function initGallery() {
    const mainImage = document.getElementById('main-image') as HTMLImageElement;
    const thumbnails = document.querySelectorAll('.thumbnail-btn');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');

    if (!mainImage) return;

    let currentIndex = 0;
    const images = Array.from(thumbnails).map(t => t.getAttribute('data-image'));

    function updateGallery(index) {
        if (!images[index]) return;
        
        mainImage.style.opacity = '0.5';
        setTimeout(() => {
            mainImage.src = images[index];
            mainImage.style.opacity = '1';
        }, 150);

        thumbnails.forEach((t, i) => {
            if (i === index) {
                t.classList.add('border-primary');
                t.classList.remove('border-transparent');
            } else {
                t.classList.remove('border-primary');
                t.classList.add('border-transparent');
            }
        });
        currentIndex = index;
    }

    thumbnails.forEach((thumb, index) => {
      thumb.addEventListener('click', () => updateGallery(index));
    });

    if (prevBtn) {
        prevBtn.addEventListener('click', () => {
            let newIndex = currentIndex - 1;
            if (newIndex < 0) newIndex = images.length - 1;
            updateGallery(newIndex);
        });
    }

    if (nextBtn) {
        nextBtn.addEventListener('click', () => {
            let newIndex = currentIndex + 1;
            if (newIndex >= images.length) newIndex = 0;
            updateGallery(newIndex);
        });
    }
  }
</script>